rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isActiveUser() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    // projects (owner or in collaborators; compat: docs without collaborators = owner only)
    function isProjectMember(projectId) {
      let p = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return p.userId == request.auth.uid
        || request.auth.uid in p.get('collaborators', []);
    }

    // users
    match /users/{uid} {
      allow read: if isOwner(uid) && isActiveUser() || isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == 'user' && request.resource.data.active == true;
      allow update: if isOwner(uid)
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && !('active' in request.resource.data.diff(resource.data).affectedKeys())
        || isAdmin();
      allow delete: if isAdmin();
    }

    // transactions: own docs OR docs in a project where user is owner/collaborator
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && isActiveUser()
        && (resource.data.userId == request.auth.uid
            || (resource.data.get('projectId', null) != null && isProjectMember(resource.data.projectId)));
      allow create: if isAuthenticated() && isActiveUser()
        && request.resource.data.userId == request.auth.uid
        && (request.resource.data.get('projectId', null) == null || isProjectMember(request.resource.data.projectId));
      allow update, delete: if isAuthenticated() && isActiveUser()
        && (resource.data.userId == request.auth.uid
            || (resource.data.get('projectId', null) != null && isProjectMember(resource.data.projectId)));
    }

    // budgets: docId = uid or uid_projectId; allow if owner or project member
    match /budgets/{docId} {
      allow read, update, delete: if isAuthenticated() && isActiveUser()
        && (docId.matches('^' + request.auth.uid + '.*')
            || (resource.data.get('projectId', null) != null && isProjectMember(resource.data.projectId)));
      allow create: if isAuthenticated() && isActiveUser()
        && (docId.matches('^' + request.auth.uid + '.*')
            || (request.resource.data.get('projectId', null) != null && isProjectMember(request.resource.data.projectId)));
    }

    // projects: read/update if owner or in collaborators; delete/create only owner
    match /projects/{projectId} {
      allow read: if isAuthenticated() && isActiveUser()
        && (resource.data.userId == request.auth.uid
            || request.auth.uid in resource.data.get('collaborators', []));
      allow create: if isAuthenticated() && isActiveUser() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isActiveUser() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && isActiveUser() && resource.data.userId == request.auth.uid;
    }

    // tasks: own or project member
    match /tasks/{taskId} {
      allow read, write: if isAuthenticated() && isActiveUser()
        && (resource.data.userId == request.auth.uid
            || (resource.data.get('projectId', null) != null && isProjectMember(resource.data.projectId)));
      allow create: if isAuthenticated() && isActiveUser()
        && request.resource.data.userId == request.auth.uid
        && (resource.data.get('projectId', null) != null && isProjectMember(request.resource.data.projectId));
    }

    // invites: sender (fromUid) or recipient (by email/uid) can read/update
    match /invites/{inviteId} {
      allow read: if isAuthenticated() && isActiveUser()
        && (
          resource.data.fromUid == request.auth.uid
          || resource.data.get('toUid', '') == request.auth.uid
          || (resource.data.get('toEmail', '') != '' && resource.data.toEmail == userEmail())
        );
      allow create: if isAuthenticated() && isActiveUser() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuthenticated() && isActiveUser()
        && (
          resource.data.fromUid == request.auth.uid
          || resource.data.get('toUid', '') == request.auth.uid
          || (resource.data.get('toEmail', '') != '' && resource.data.toEmail == userEmail())
        );
      allow delete: if isAuthenticated() && isActiveUser() && resource.data.fromUid == request.auth.uid;
    }

    // notifications: only the recipient (userId) can read/update
    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && isActiveUser() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isActiveUser();
      allow delete: if isAuthenticated() && isActiveUser() && resource.data.userId == request.auth.uid;
    }

    // Bloqueia tudo que não foi explicitamente liberado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
