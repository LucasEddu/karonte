rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isActiveUser() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }

    // ─── Coleção: users ──────────────────────────────────────────
    match /users/{uid} {
      // Qualquer usuário autenticado e ativo pode ler seu próprio documento.
      // Admin pode ler todos.
      allow read: if isOwner(uid) && isActiveUser() || isAdmin();

      // Usuário pode criar/atualizar seu próprio doc, mas NÃO pode definir role=admin.
      allow create: if isOwner(uid)
        && request.resource.data.role == 'user'
        && request.resource.data.active == true;

      // Usuário pode atualizar campos permitidos do próprio doc (ex: username),
      // mas não pode alterar 'role' nem 'active'.
      allow update: if isOwner(uid)
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && !('active' in request.resource.data.diff(resource.data).affectedKeys())
        || isAdmin();

      // Só admin pode deletar usuários.
      allow delete: if isAdmin();
    }

    // ─── Coleção: transactions ───────────────────────────────────
    match /transactions/{transactionId} {
      // Usuário só acessa suas próprias transações.
      allow read, write: if isAuthenticated()
        && isActiveUser()
        && resource.data.userId == request.auth.uid;

      // Na criação, garante que userId pertence ao criador.
      allow create: if isAuthenticated()
        && isActiveUser()
        && request.resource.data.userId == request.auth.uid;
    }

    // ─── Coleção: budgets ────────────────────────────────────────
    match /budgets/{uid} {
      // Usuário só acessa seus próprios orçamentos.
      allow read, write: if isAuthenticated() && isActiveUser() && isOwner(uid);
    }

    // ─── Bloqueia tudo que não foi explicitamente liberado ───────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
