rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isActiveUser() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }
    function userEmail() {
      return request.auth.token.email;
    }

    function projectData(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    function isProjectMember(projectId) {
      let p = projectData(projectId);
      return p.userId == request.auth.uid
        || request.auth.uid in p.get('collaborators', []);
    }

    function projectRole(projectId) {
      let p = projectData(projectId);
      return p.userId == request.auth.uid
        ? 'owner'
        : (
          request.auth.uid in p.get('collaboratorRoles', {})
            ? p.collaboratorRoles[request.auth.uid]
            : 'view'
        );
    }

    function canAddInProject(projectId) {
      let role = projectRole(projectId);
      return role == 'owner' || role == 'add' || role == 'manage';
    }

    function canDeleteInProject(projectId) {
      let role = projectRole(projectId);
      return role == 'owner' || role == 'manage';
    }

    function canManageProject(projectId) {
      return projectRole(projectId) == 'owner';
    }

    match /users/{uid} {
      allow read: if isOwner(uid) && isActiveUser() || isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == 'user' && request.resource.data.active == true;
      allow update: if isOwner(uid)
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && !('active' in request.resource.data.diff(resource.data).affectedKeys())
        || isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || (
            resource.data.get('projectId', null) != null
            && isProjectMember(resource.data.projectId)
          )
        );

      allow create: if isAuthenticated() && isActiveUser()
        && request.resource.data.userId == request.auth.uid
        && (
          request.resource.data.get('projectId', null) == null
          || (
            isProjectMember(request.resource.data.projectId)
            && canAddInProject(request.resource.data.projectId)
          )
        );

      allow update: if isAuthenticated() && isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || (
            resource.data.get('projectId', null) != null
            && isProjectMember(resource.data.projectId)
            && canAddInProject(resource.data.projectId)
          )
        );

      allow delete: if isAuthenticated() && isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || (
            resource.data.get('projectId', null) != null
            && isProjectMember(resource.data.projectId)
            && canDeleteInProject(resource.data.projectId)
          )
        );
    }

    match /budgets/{docId} {
      allow read, update, delete: if isAuthenticated() && isActiveUser()
        && (
          docId.matches('^' + request.auth.uid + '.*')
          || (
            resource.data.get('projectId', null) != null
            && isProjectMember(resource.data.projectId)
          )
        );
      allow create: if isAuthenticated() && isActiveUser()
        && (
          docId.matches('^' + request.auth.uid + '.*')
          || (
            request.resource.data.get('projectId', null) != null
            && isProjectMember(request.resource.data.projectId)
            && canAddInProject(request.resource.data.projectId)
          )
        );
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || request.auth.uid in resource.data.get('collaborators', [])
        );
      allow create: if isAuthenticated() && isActiveUser() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isActiveUser()
        && (
          canManageProject(projectId)
          || (
            !(request.auth.uid in resource.data.get('collaborators', []))
            && request.auth.uid in request.resource.data.get('collaborators', [])
            && resource.data.userId == request.resource.data.userId
          )
        );
      allow delete: if isAuthenticated() && isActiveUser() && canManageProject(projectId);
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated() && isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || (
            resource.data.get('projectId', null) != null
            && isProjectMember(resource.data.projectId)
          )
        );

      allow create: if isAuthenticated() && isActiveUser()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.get('projectId', null) != null
        && isProjectMember(request.resource.data.projectId)
        && canAddInProject(request.resource.data.projectId);

      allow update: if isAuthenticated() && isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || (
            resource.data.get('projectId', null) != null
            && isProjectMember(resource.data.projectId)
            && canAddInProject(resource.data.projectId)
          )
        );

      allow delete: if isAuthenticated() && isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || (
            resource.data.get('projectId', null) != null
            && isProjectMember(resource.data.projectId)
            && canDeleteInProject(resource.data.projectId)
          )
        );
    }

    match /invites/{inviteId} {
      allow read: if isAuthenticated() && isActiveUser()
        && (
          resource.data.fromUid == request.auth.uid
          || resource.data.get('toUid', '') == request.auth.uid
          || (resource.data.get('toEmail', '') != '' && resource.data.toEmail == userEmail())
        );
      allow create: if isAuthenticated() && isActiveUser() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuthenticated() && isActiveUser()
        && (
          resource.data.fromUid == request.auth.uid
          || resource.data.get('toUid', '') == request.auth.uid
          || (resource.data.get('toEmail', '') != '' && resource.data.toEmail == userEmail())
        );
      allow delete: if isAuthenticated() && isActiveUser() && resource.data.fromUid == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && isActiveUser() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isActiveUser();
      allow delete: if isAuthenticated() && isActiveUser() && resource.data.userId == request.auth.uid;
    }

    match /userCategories/{uid} {
      allow read, write: if isAuthenticated() && isActiveUser() && request.auth.uid == uid;
    }

    match /creditCards/{cardId} {
      allow read: if isAuthenticated() && isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || (
            resource.data.get('projectId', null) != null
            && resource.data.projectId != 'geral'
            && isProjectMember(resource.data.projectId)
          )
        );
      allow create: if isAuthenticated() && isActiveUser()
        && request.resource.data.userId == request.auth.uid
        && (
          request.resource.data.get('projectId', null) == null
          || request.resource.data.projectId == 'geral'
          || (
            isProjectMember(request.resource.data.projectId)
            && canManageProject(request.resource.data.projectId)
          )
        );
      allow update, delete: if isAuthenticated() && isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || (
            resource.data.get('projectId', null) != null
            && resource.data.projectId != 'geral'
            && canManageProject(resource.data.projectId)
          )
        );
    }

    match /insights/{docId} {
      allow read, write: if isAuthenticated() && isActiveUser()
        && docId.matches('^' + request.auth.uid + '_.*');
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
